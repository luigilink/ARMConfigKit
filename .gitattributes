# ARMConfigKit line-ending and encoding policy
#
# The PowerShell helper scripts may run under Windows PowerShell 5.1 as well as
# PowerShell 7. Without a BOM, Windows PowerShell 5.1 reads .ps1/.psm1/.psd1 as
# ANSI (the system code page), which corrupts any non-ASCII character. We
# therefore store all PowerShell files as UTF-8 with BOM (the BOM is part of the
# committed content) and check them out with CRLF line endings.
#
# Terraform, YAML and Markdown files must NOT carry a BOM (it breaks some parsers
# and terraform fmt) and use LF.

* text=auto eol=lf

# PowerShell -- committed with a UTF-8 BOM, checked out with CRLF
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Terraform / config / docs -- no BOM, LF
*.tf      text eol=lf
*.tfvars  text eol=lf
*.hcl     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.json    text eol=lf

# Binary artifacts
*.png binary
*.zip binary
